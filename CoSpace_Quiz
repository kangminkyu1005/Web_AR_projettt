<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>코스페이스 역량 평가 시스템</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;700&display=swap');
        body { font-family: 'Noto Sans KR', sans-serif; background-color: #f1f5f9; }
        
        .page { display: none !important; }
        .page.active { display: block !important; }
        #quiz-page.active { display: flex !important; }
        #teacher-login-modal.active, #custom-confirm-modal.active, #detail-modal.active { display: flex !important; }

        #teacher-login-modal, #custom-confirm-modal, #detail-modal { display: none; }

        .fade-in { animation: fadeIn 0.5s ease-out; }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .star-rating { color: #e2e8f0; position: relative; display: inline-block; font-size: 1.25rem; }
        .star-rating .filled { color: #fbbf24; position: absolute; top: 0; left: 0; white-space: nowrap; overflow: hidden; }

        .progress-fill { transition: width 0.4s ease-in-out; }
        .tab-btn.active { border-bottom: 3px solid #3b82f6; color: #3b82f6; }
        
        #question-text { 
            word-break: keep-all; 
            overflow-wrap: break-word; 
            white-space: normal;
        }

        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #f1f5f9; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }

        .pagination-btn.active { background-color: #3b82f6; color: white; border-color: #3b82f6; }
    </style>
</head>
<body class="p-4 md:p-8">

    <div id="app" class="max-w-6xl mx-auto">
        <!-- 1. 메인 화면 -->
        <div id="main-page" class="page active bg-white rounded-2xl shadow-xl p-12 text-center">
            <h1 class="text-4xl font-bold text-slate-800 mb-4">코스페이스 역량 평가</h1>
            <p class="text-slate-500 mb-10">자신의 로봇 프로그래밍 실력을 점검하고 피드백을 받아보세요.</p>
            
            <div class="max-w-md mx-auto space-y-4">
                <div class="text-left">
                    <label class="block text-sm font-medium text-slate-700 mb-1 ml-1">학생 이름</label>
                    <input type="text" id="student-name" placeholder="이름을 입력하세요" 
                        oninput="toggleStartButton()" 
                        onkeydown="if(event.key === 'Enter') startAssessment()"
                        class="w-full p-4 border-2 border-slate-200 rounded-xl focus:border-blue-500 outline-none text-lg transition-all">
                </div>
                <button id="start-btn" onclick="startAssessment()" disabled
                    class="w-full bg-slate-200 text-slate-400 font-bold py-4 rounded-xl shadow-lg transition duration-200 cursor-not-allowed">
                    평가 시작하기 <i class="fa-solid fa-play ml-2"></i>
                </button>
            </div>

            <div class="mt-16 pt-8 border-t border-slate-100">
                <button onclick="openTeacherAuth()" 
                    class="text-slate-400 hover:text-blue-600 text-sm font-medium flex items-center justify-center mx-auto gap-2 transition-colors">
                    <i class="fa-solid fa-user-tie"></i> 선생님 전용 관리 도구
                </button>
            </div>
        </div>

        <!-- 2. 선생님 인증 모달 -->
        <div id="teacher-login-modal" class="fixed inset-0 bg-slate-900/60 items-center justify-center z-50 backdrop-blur-sm">
            <div class="bg-white p-8 rounded-2xl shadow-2xl w-full max-w-sm border border-slate-100">
                <div class="text-center mb-6">
                    <div class="w-16 h-16 bg-blue-50 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fa-solid fa-lock text-blue-600 text-2xl"></i>
                    </div>
                    <h3 class="text-2xl font-bold text-slate-800">선생님 인증</h3>
                    <p class="text-slate-500 text-sm mt-1">비밀번호를 입력하세요.</p>
                </div>
                <input type="password" id="teacher-pw" placeholder="비밀번호" 
                    oninput="toggleTeacherLoginButton()"
                    onkeydown="if(event.key === 'Enter') processLogin()"
                    class="w-full p-4 border rounded-xl text-center text-xl tracking-widest focus:ring-2 focus:ring-blue-500 outline-none transition-all">
                <div id="pw-error-msg" class="hidden text-red-500 text-xs mt-2 font-bold text-center">
                    비밀번호가 틀렸습니다.
                </div>
                <div class="flex gap-2 mt-6">
                    <button onclick="closeTeacherAuth()" class="flex-1 py-3 text-slate-500 font-medium hover:bg-slate-50 rounded-xl">취소</button>
                    <button id="teacher-login-btn" onclick="processLogin()" disabled class="flex-1 py-3 bg-slate-200 text-slate-400 font-bold rounded-xl">인증하기</button>
                </div>
            </div>
        </div>

        <!-- 커스텀 컨펌 모달 -->
        <div id="custom-confirm-modal" class="fixed inset-0 bg-slate-900/60 items-center justify-center z-[60] backdrop-blur-sm">
            <div class="bg-white p-8 rounded-2xl shadow-2xl w-full max-w-sm border border-slate-100 text-center">
                <div class="w-16 h-16 bg-red-50 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i class="fa-solid fa-triangle-exclamation text-red-500 text-2xl"></i>
                </div>
                <h3 class="text-xl font-bold text-slate-800 mb-2">실행하시겠습니까?</h3>
                <p id="confirm-msg" class="text-slate-500 text-sm mb-8">해당 동작은 취소할 수 없습니다.</p>
                <div class="flex gap-2">
                    <button id="confirm-cancel-btn" class="flex-1 py-3 text-slate-500 font-medium hover:bg-slate-50 rounded-xl">취소</button>
                    <button id="confirm-ok-btn" class="flex-1 py-3 bg-red-500 text-white font-bold rounded-xl hover:bg-red-600">확인</button>
                </div>
            </div>
        </div>

        <!-- 3. 단원 제목 화면 -->
        <div id="unit-intro-page" class="page bg-white rounded-2xl shadow-xl p-16 text-center fade-in">
            <div class="flex justify-start mb-4">
                <button onclick="confirmResetToHome()" class="text-slate-400 hover:text-red-500 transition-colors flex items-center gap-2 text-sm font-bold">
                    <i class="fa-solid fa-house"></i> 처음으로
                </button>
            </div>
            <div id="unit-icon-box" class="w-24 h-24 bg-blue-600 text-white rounded-3xl flex items-center justify-center mx-auto mb-8 text-4xl shadow-lg">
                <i class="fa-solid fa-layer-group"></i>
            </div>
            <p class="text-blue-600 font-bold tracking-widest mb-2" id="unit-number-label">UNIT 01</p>
            <h2 id="unit-intro-title" class="text-5xl font-black text-slate-800 mb-6">단원명</h2>
            <p id="unit-intro-desc" class="text-slate-500 text-lg mb-12 max-w-lg mx-auto leading-relaxed">설명...</p>
            <button onclick="goToQuiz()" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-5 px-12 rounded-2xl shadow-xl transition-all transform hover:scale-105">
                <span id="unit-action-btn-text">문제 풀기 시작</span> <i class="fa-solid fa-arrow-right ml-2"></i>
            </button>
        </div>

        <!-- 4. 퀴즈 화면 -->
        <div id="quiz-page" class="page bg-white rounded-2xl shadow-xl p-8 min-h-[500px] flex flex-col fade-in">
            <div class="flex justify-between items-center mb-4">
                <button onclick="confirmResetToHome()" class="text-slate-400 hover:text-red-500 transition-colors flex items-center gap-2 text-sm font-bold">
                    <i class="fa-solid fa-house"></i> 처음으로
                </button>
                <div class="text-slate-400 font-bold" id="quiz-progress">문제 1 / 5</div>
            </div>
            <div class="w-full bg-slate-100 h-2 rounded-full mb-6 overflow-hidden">
                <div id="progress-bar-fill" class="progress-fill bg-blue-500 h-full w-0"></div>
            </div>
            <div class="flex justify-between items-center mb-8 border-b border-slate-100 pb-4">
                <span id="unit-tag" class="bg-blue-100 text-blue-700 px-4 py-1.5 rounded-full text-sm font-bold shadow-sm">단원명</span>
            </div>
            <div class="flex-grow">
                <h2 id="question-text" class="text-2xl font-bold text-slate-800 mb-8 leading-relaxed">질문 내용</h2>
                <div id="options-container" class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8"></div>
            </div>
            <button id="next-btn" onclick="handleNextQuestion()" disabled class="w-full bg-slate-200 text-slate-400 font-bold py-4 rounded-xl transition duration-200 cursor-not-allowed">
                다음 단계로 <i class="fa-solid fa-chevron-right ml-2"></i>
            </button>
        </div>

        <!-- 5. 평가 완료 화면 -->
        <div id="result-page" class="page bg-white rounded-2xl shadow-xl p-10 text-center">
            <div class="mb-6"><i class="fa-solid fa-circle-check text-6xl text-green-500"></i></div>
            <h2 class="text-3xl font-bold text-slate-800 mb-2"><span id="result-name"></span> 학생 평가 리포트</h2>
            <p class="text-slate-500 mb-10">모든 평가가 완료되었습니다.</p>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12 text-left" id="result-summary"></div>
            <button onclick="resetToHome()" class="bg-slate-800 hover:bg-slate-900 text-white font-bold py-4 px-10 rounded-xl shadow-lg">메인으로 이동</button>
        </div>

        <!-- 6. 선생님 대시보드 -->
        <div id="teacher-dashboard-page" class="page bg-white rounded-2xl shadow-xl p-8">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4 border-b pb-4">
                <div>
                    <h2 class="text-3xl font-bold text-slate-800">선생님 관리 도구</h2>
                    <div class="flex gap-6 mt-4">
                        <button onclick="switchTeacherTab('results')" id="tab-results" class="tab-btn font-bold pb-2 active">평가 결과</button>
                        <button onclick="switchTeacherTab('edit-quiz')" id="tab-edit-quiz" class="tab-btn font-bold pb-2 text-slate-400">문제 개별 수정</button>
                        <button onclick="switchTeacherTab('edit-survey')" id="tab-edit-survey" class="tab-btn font-bold pb-2 text-slate-400">설문 개별 수정</button>
                        <button onclick="switchTeacherTab('excel-sync')" id="tab-excel-sync" class="tab-btn font-bold pb-2 text-slate-400">엑셀 데이터 연동</button>
                    </div>
                </div>
                <button onclick="resetToHome()" class="bg-slate-100 px-5 py-2.5 rounded-xl hover:bg-slate-200 text-slate-600 font-medium">로그아웃</button>
            </div>

            <div id="section-results" class="teacher-section">
                <div class="overflow-x-auto rounded-xl border border-slate-200">
                    <table class="w-full text-left border-collapse">
                        <thead><tr class="bg-slate-50"><th class="p-4 font-bold text-slate-600 border-b">날짜</th><th class="p-4 font-bold text-slate-600 border-b">학생명</th><th class="p-4 font-bold text-slate-600 border-b">평균 성취도</th><th class="p-4 font-bold text-slate-600 border-b">상세</th></tr></thead>
                        <tbody id="student-list-body"></tbody>
                    </table>
                </div>
                <div id="results-pagination" class="flex justify-center items-center gap-2 mt-6"></div>
            </div>

            <div id="section-edit-quiz" class="teacher-section hidden">
                <div class="grid grid-cols-3 gap-4 mb-8">
                    <button onclick="loadQuizEdit(1)" class="unit-edit-btn p-4 rounded-xl border-2 border-blue-500 bg-blue-50 text-blue-700 font-bold">1단원</button>
                    <button onclick="loadQuizEdit(2)" class="unit-edit-btn p-4 rounded-xl border-2 border-slate-100 bg-white text-slate-500 font-bold">2단원</button>
                    <button onclick="loadQuizEdit(3)" class="unit-edit-btn p-4 rounded-xl border-2 border-slate-100 bg-white text-slate-500 font-bold">3단원</button>
                </div>
                <div id="quiz-edit-list" class="space-y-6"></div>
                <div id="quiz-pagination" class="flex justify-center items-center gap-2 mt-6"></div>
                <button onclick="addNewQuestionToUnit()" class="w-full mt-8 border-2 border-dashed border-slate-300 py-6 rounded-2xl text-slate-400 font-bold hover:bg-slate-50 transition-all">
                    <i class="fa-solid fa-plus mr-2"></i> 새로운 문제 추가하기
                </button>
            </div>

            <div id="section-edit-survey" class="teacher-section hidden">
                <div class="mb-8 p-4 bg-amber-50 rounded-xl border border-amber-100">
                    <p class="text-amber-800 text-sm font-bold"><i class="fa-solid fa-circle-info mr-2"></i>4단원(코스페이스 스스로 점검)은 설문 형식으로 정답이 없습니다.</p>
                </div>
                <div id="survey-edit-list" class="space-y-6"></div>
                <div id="survey-pagination" class="flex justify-center items-center gap-2 mt-6"></div>
                <button onclick="addNewSurveyToUnit()" class="w-full mt-8 border-2 border-dashed border-slate-300 py-6 rounded-2xl text-slate-400 font-bold hover:bg-slate-50 transition-all">
                    <i class="fa-solid fa-plus mr-2"></i> 새로운 설문 문항 추가하기
                </button>
            </div>

            <div id="section-excel-sync" class="teacher-section hidden">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="bg-blue-50 p-8 rounded-3xl border border-blue-100 text-center">
                        <div class="w-16 h-16 bg-blue-600 text-white rounded-full flex items-center justify-center mx-auto mb-4 text-2xl">
                            <i class="fa-solid fa-file-export"></i>
                        </div>
                        <h3 class="text-xl font-bold text-blue-900 mb-2">엑셀 양식 다운로드</h3>
                        <p class="text-sm text-blue-600 mb-6">현재 시스템의 모든 문제를 엑셀 파일로 변환하여 내려받습니다.</p>
                        <button onclick="downloadExcelTemplate()" class="bg-blue-600 text-white px-8 py-3 rounded-xl font-bold hover:bg-blue-700 shadow-lg">양식 내려받기</button>
                    </div>
                    <div class="bg-green-50 p-8 rounded-3xl border border-green-100 text-center">
                        <div class="w-16 h-16 bg-green-600 text-white rounded-full flex items-center justify-center mx-auto mb-4 text-2xl">
                            <i class="fa-solid fa-file-import"></i>
                        </div>
                        <h3 class="text-xl font-bold text-green-900 mb-2">엑셀 파일 업로드</h3>
                        <p class="text-sm text-green-600 mb-6">수정한 엑셀 파일을 업로드하여 문제를 일괄 업데이트합니다.</p>
                        <input type="file" id="excel-input" accept=".xlsx, .xls" class="hidden" onchange="handleExcelUpload(this)">
                        <button onclick="document.getElementById('excel-input').click()" class="bg-green-600 text-white px-8 py-3 rounded-xl font-bold hover:bg-green-700 shadow-lg">파일 선택 및 적용</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- 7. 상세 평가 정보 (수정됨: 피드백이 메인) -->
        <div id="teacher-detail-page" class="page bg-white rounded-2xl shadow-xl p-8">
            <div class="flex justify-between items-center mb-8 border-b pb-4">
                <button onclick="showPage('teacher-dashboard-page')" class="text-blue-600 hover:text-blue-800 font-bold flex items-center gap-2">
                    <i class="fa-solid fa-arrow-left"></i> 목록으로
                </button>
                <div class="flex gap-2">
                    <button onclick="openDetailModal('report')" class="bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold py-2.5 px-5 rounded-xl flex items-center gap-2 transition-all">
                        <i class="fa-solid fa-chart-pie"></i> 리포트 확인
                    </button>
                    <button onclick="openDetailModal('analysis')" class="bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold py-2.5 px-5 rounded-xl flex items-center gap-2 transition-all">
                        <i class="fa-solid fa-list-check"></i> 문항 분석 확인
                    </button>
                    <button onclick="showSurveyResultPage()" class="bg-slate-800 hover:bg-slate-900 text-white font-bold py-2.5 px-5 rounded-xl flex items-center gap-2 transition-all shadow-md">
                        <i class="fa-solid fa-clipboard-list"></i> 설문 결과
                    </button>
                </div>
            </div>

            <div class="max-w-4xl mx-auto space-y-8 py-4">
                <div class="text-center mb-8">
                    <h2 class="text-3xl font-black text-slate-800"><span id="detail-student-name" class="text-blue-600"></span> 학생 피드백 작성</h2>
                    <p class="text-slate-500 mt-2">평가 결과를 바탕으로 맞춤형 피드백을 전달하세요.</p>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-2">
                        <label class="block text-sm font-bold text-slate-600 ml-1">자동 생성 피드백 (수정 가능)</label>
                        <textarea id="auto-feedback" class="w-full h-64 p-6 bg-slate-50 border border-slate-200 rounded-2xl text-slate-700 focus:ring-2 focus:ring-blue-500 outline-none transition-all leading-relaxed" placeholder="성취도에 따른 자동 피드백 내용"></textarea>
                    </div>
                    <div class="space-y-2">
                        <label class="block text-sm font-bold text-slate-600 ml-1">선생님 개별 코멘트</label>
                        <textarea id="teacher-comment" class="w-full h-64 p-6 border border-slate-200 rounded-2xl text-slate-700 focus:ring-2 focus:ring-blue-500 outline-none transition-all leading-relaxed" placeholder="학생에게 전하고 싶은 말을 자유롭게 작성하세요."></textarea>
                    </div>
                </div>
                
                <button onclick="saveFeedbackChanges()" class="w-full bg-blue-600 text-white font-black py-5 rounded-2xl hover:bg-blue-700 shadow-xl transition-all transform hover:scale-[1.01] flex items-center justify-center gap-3 text-lg">
                    <i class="fa-solid fa-floppy-disk"></i> 피드백 저장하기
                </button>
            </div>
        </div>

        <!-- 8. 상세 정보 모달 (리포트/문항분석) -->
        <div id="detail-modal" class="fixed inset-0 bg-slate-900/60 items-center justify-center z-50 backdrop-blur-sm p-4">
            <div class="bg-white rounded-3xl shadow-2xl w-full max-w-3xl max-h-[90vh] flex flex-col overflow-hidden fade-in">
                <div class="p-6 border-b flex justify-between items-center bg-slate-50">
                    <h3 id="modal-title" class="text-xl font-bold text-slate-800">상세 정보</h3>
                    <button onclick="closeDetailModal()" class="text-slate-400 hover:text-slate-600 text-2xl"><i class="fa-solid fa-xmark"></i></button>
                </div>
                <div class="p-8 overflow-y-auto flex-grow" id="modal-content">
                    <!-- 리포트 컨텐츠 -->
                    <div id="modal-report-content" class="hidden space-y-8">
                        <div id="detail-stats-container" class="space-y-6"></div>
                    </div>
                    <!-- 문항분석 컨텐츠 -->
                    <div id="modal-analysis-content" class="hidden">
                        <div class="overflow-x-auto border rounded-2xl">
                            <table class="w-full text-left border-collapse text-sm">
                                <thead>
                                    <tr class="bg-slate-50 border-b">
                                        <th class="p-4 font-bold text-slate-600">문제</th>
                                        <th class="p-4 font-bold text-slate-600">학생 선택</th>
                                        <th class="p-4 font-bold text-slate-600">정답</th>
                                        <th class="p-4 font-bold text-slate-600 text-center">결과</th>
                                    </tr>
                                </thead>
                                <tbody id="question-analysis-body"></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 9. 설문조사 결과 확인 페이지 -->
        <div id="survey-result-page" class="page bg-white rounded-2xl shadow-xl p-8">
            <button onclick="showPage('teacher-detail-page')" class="mb-8 text-blue-600 hover:text-blue-800 font-bold flex items-center gap-2">
                <i class="fa-solid fa-arrow-left"></i> 돌아가기
            </button>
            <h2 class="text-3xl font-bold text-slate-800 mb-6"><span id="survey-result-name" class="text-blue-600"></span> 학생 설문 결과</h2>
            <div id="survey-result-list" class="space-y-6"></div>
        </div>
    </div>

    <!-- 커스텀 알림 박스 -->
    <div id="custom-alert" class="fixed top-4 left-1/2 -translate-x-1/2 bg-slate-800 text-white px-6 py-3 rounded-xl shadow-2xl z-[100] transition-all transform -translate-y-20 opacity-0 pointer-events-none">
        <span id="alert-msg"></span>
    </div>

    <script>
        const MASTER_PW = "4057066";
        let currentStudent = "";
        let currentUnit = 1;
        let currentQuestionIdx = 0;
        let scores = { 1: 0, 2: 0, 3: 0, 4: 0 };
        let quizAnswers = { 1: [], 2: [], 3: [] }; 
        let surveyAnswers = { 4: [] }; 
        let assessmentRecords = []; 
        let editingUnit = 1;
        let viewingId = null;

        const ITEMS_PER_PAGE = 5;
        let currentResultsPage = 1;
        let currentQuizPage = 1;
        let currentSurveyPage = 1;

        const unitInfo = { 
            1: { title: "로봇 동작", desc: "로봇의 모터 제어와 기본 주행 원리를 평가합니다.", icon: "fa-gear" },
            2: { title: "조건식", desc: "센서 값에 따라 로봇이 스스로 판단하는 알고리즘을 평가합니다.", icon: "fa-code-branch" },
            3: { title: "프로그램 전략", desc: "경기 상황에 맞는 최적의 주행 전략과 예외 처리를 평가합니다.", icon: "fa-chess" },
            4: { title: "코스페이스 스스로 점검", desc: "학습 과정을 스스로 되돌아보고 성취를 점검합니다.", icon: "fa-user-check" }
        };

        let quizData = JSON.parse(localStorage.getItem('cospace_quiz_v3')) || {
            1: [
                { q: "왼쪽 모터 30, 오른쪽 50일 때 로봇의 움직임은?", a: ["왼쪽으로 회전한다.", "오른쪽으로 회전한다.", "직진한다.", "제자리에서 회전한다."], correct: 0 },
                { q: "장애물 감지 후 즉시 멈추려면 모터 출력을 어떻게 설정해야 합니까?", a: ["좌우 모터 출력 0", "좌우 모터 출력 100", "좌측 50, 우측 -50", "좌우 모터 출력 -20"], correct: 0 }
            ],
            2: [
                { q: "초음파 센서 값이 10보다 작을 때 멈추는 조건식은?", a: ["if (Distance < 10)", "if (Distance > 10)", "if (Distance == 10)", "while (Distance > 10)"], correct: 0 },
                { q: "참인 경우와 거짓인 경우 경로를 나눌 때 사용하는 구문은?", a: ["if - else 구문", "for 반복문", "변수 선언문", "단독 if 구문"], correct: 0 }
            ],
            3: [
                { q: "경기에서 높은 점수를 얻기 위해 가장 먼저 고려해야 할 요소는?", a: ["미션 오브젝트 점수 확인", "외관 디자인", "무조건 빠른 주행", "상대방 방해"], correct: 0 }
            ],
            4: [
                { q: "오늘 로봇 프로그래밍 활동에 적극적으로 참여했나요?", a: ["매우 그렇다", "그렇다", "보통이다", "그렇지 않다"], correct: -1 },
                { q: "가장 재미있었거나 성취감을 느낀 부분은 무엇인가요?", a: ["코드 작성", "로봇 동작 확인", "문제 해결", "팀 협력"], correct: -1 }
            ]
        };

        function showAlert(msg) {
            const el = document.getElementById('custom-alert');
            document.getElementById('alert-msg').innerText = msg;
            el.classList.remove('opacity-0', '-translate-y-20', 'pointer-events-none');
            setTimeout(() => el.classList.add('opacity-0', '-translate-y-20', 'pointer-events-none'), 2500);
        }

        function customConfirm(msg, callback) {
            const modal = document.getElementById('custom-confirm-modal');
            document.getElementById('confirm-msg').innerText = msg;
            const okBtn = document.getElementById('confirm-ok-btn');
            const cancelBtn = document.getElementById('confirm-cancel-btn');
            modal.classList.add('active');
            const cleanup = () => { modal.classList.remove('active'); okBtn.onclick = null; cancelBtn.onclick = null; };
            okBtn.onclick = () => { cleanup(); callback(); };
            cancelBtn.onclick = () => cleanup();
        }

        function showPage(pageId) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.getElementById(pageId).classList.add('active');
            window.scrollTo(0, 0);
        }

        function saveQuizToLocal() {
            localStorage.setItem('cospace_quiz_v3', JSON.stringify(quizData));
        }

        function confirmResetToHome() {
            customConfirm("메인 화면으로 돌아가시겠습니까? 진행 상황은 저장되지 않습니다.", () => { resetToHome(); });
        }

        function downloadExcelTemplate() {
            const data = [];
            Object.keys(quizData).forEach(u => {
                quizData[u].forEach(q => {
                    data.push({ "단원": u, "질문": q.q, "보기1": q.a[0] || "", "보기2": q.a[1] || "", "보기3": q.a[2] || "", "보기4": q.a[3] || "", "정답번호": q.correct === -1 ? "-" : q.correct + 1 });
                });
            });
            const ws = XLSX.utils.json_to_sheet(data);
            const wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, "Data");
            XLSX.writeFile(wb, "cospace_data_full.xlsx");
        }

        function handleExcelUpload(input) {
            const file = input.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = (e) => {
                const workbook = XLSX.read(new Uint8Array(e.target.result), { type: 'array' });
                const rows = XLSX.utils.sheet_to_json(workbook.Sheets[workbook.SheetNames[0]]);
                if (rows.length === 0) return showAlert("데이터가 없습니다.");
                customConfirm("기존 데이터를 교체하시겠습니까?", () => {
                    const newData = { 1: [], 2: [], 3: [], 4: [] };
                    rows.forEach(row => {
                        const u = row["단원"];
                        if (newData[u]) {
                            const correctVal = row["정답번호"] === "-" ? -1 : (parseInt(row["정답번호"]) - 1);
                            newData[u].push({ q: row["질문"], a: [row["보기1"], row["보기2"], row["보기3"], row["보기4"]].filter(x => x), correct: correctVal });
                        }
                    });
                    quizData = newData;
                    saveQuizToLocal();
                    showAlert("업데이트 완료.");
                    switchTeacherTab('results');
                    input.value = "";
                });
            };
            reader.readAsArrayBuffer(file);
        }

        function switchTeacherTab(tabName) {
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active', 'text-blue-600'));
            document.querySelectorAll('.teacher-section').forEach(s => s.classList.add('hidden'));
            document.getElementById(`tab-${tabName}`).classList.add('active', 'text-blue-600');
            document.getElementById(`section-${tabName}`).classList.remove('hidden');
            if(tabName === 'edit-quiz') { currentQuizPage = 1; loadQuizEdit(1); }
            else if(tabName === 'edit-survey') { currentSurveyPage = 1; loadSurveyEdit(); }
            else if(tabName === 'results') { currentResultsPage = 1; showTeacherDashboard(); }
        }

        function renderPagination(containerId, totalItems, currentPage, onPageChange) {
            const container = document.getElementById(containerId);
            if(!container) return;
            container.innerHTML = '';
            const totalPages = Math.ceil(totalItems / ITEMS_PER_PAGE);
            if (totalPages <= 1) return;
            for (let i = 1; i <= totalPages; i++) {
                const btn = document.createElement('button');
                btn.innerText = i;
                btn.className = `w-10 h-10 rounded-lg border font-bold transition-all ${i === currentPage ? 'bg-blue-600 text-white border-blue-600' : 'bg-white text-slate-400 hover:bg-slate-50'}`;
                btn.onclick = () => onPageChange(i);
                container.appendChild(btn);
            }
        }

        function loadQuizEdit(unitNum) {
            editingUnit = unitNum;
            document.querySelectorAll('#section-edit-quiz .unit-edit-btn').forEach((btn, idx) => {
                btn.className = (idx + 1 === unitNum) ? "unit-edit-btn p-4 rounded-xl border-2 border-blue-500 bg-blue-50 text-blue-700 font-bold" : "unit-edit-btn p-4 rounded-xl border-2 border-slate-100 bg-white text-slate-500 font-bold hover:bg-slate-50";
            });
            const listContainer = document.getElementById('quiz-edit-list');
            listContainer.innerHTML = '';
            const questions = quizData[unitNum];
            const start = (currentQuizPage - 1) * ITEMS_PER_PAGE;
            const paged = questions.slice(start, start + ITEMS_PER_PAGE);
            paged.forEach((item, pIdx) => {
                const gIdx = start + pIdx;
                const card = document.createElement('div');
                card.className = "p-6 bg-white border border-slate-200 rounded-2xl shadow-sm space-y-4 fade-in";
                card.innerHTML = `<div class="flex justify-between items-center"><span class="bg-slate-100 px-3 py-1 rounded-lg text-xs font-bold text-slate-500">문제 ${gIdx + 1}</span><button onclick="removeQuestion(${unitNum}, ${gIdx})" class="text-red-400 hover:text-red-600 text-sm"><i class="fa-solid fa-trash-can"></i> 삭제</button></div><input type="text" value="${item.q}" oninput="quizData[${unitNum}][${gIdx}].q = this.value; saveQuizToLocal();" class="w-full p-3 border rounded-xl font-bold text-slate-800 focus:border-blue-500 outline-none"><div class="grid grid-cols-1 md:grid-cols-2 gap-3">${item.a.map((opt, oIdx) => `<div class="flex items-center gap-2"><input type="radio" name="correct-${unitNum}-${gIdx}" ${item.correct === oIdx ? 'checked' : ''} onchange="quizData[${unitNum}][${gIdx}].correct = ${oIdx}; saveQuizToLocal();" class="w-4 h-4"><input type="text" value="${opt}" oninput="quizData[${unitNum}][${gIdx}].a[${oIdx}] = this.value; saveQuizToLocal();" class="flex-1 p-2 border rounded-lg text-sm outline-none"></div>`).join('')}</div>`;
                listContainer.appendChild(card);
            });
            renderPagination('quiz-pagination', questions.length, currentQuizPage, (p) => { currentQuizPage = p; loadQuizEdit(unitNum); });
        }

        function loadSurveyEdit() {
            const listContainer = document.getElementById('survey-edit-list');
            listContainer.innerHTML = '';
            const survey = quizData[4];
            const start = (currentSurveyPage - 1) * ITEMS_PER_PAGE;
            const paged = survey.slice(start, start + ITEMS_PER_PAGE);
            paged.forEach((item, pIdx) => {
                const gIdx = start + pIdx;
                const card = document.createElement('div');
                card.className = "p-6 bg-white border border-slate-200 rounded-2xl shadow-sm space-y-4 fade-in";
                card.innerHTML = `<div class="flex justify-between items-center"><span class="bg-amber-100 px-3 py-1 rounded-lg text-xs font-bold text-amber-600">설문 문항 ${gIdx + 1}</span><button onclick="removeQuestion(4, ${gIdx})" class="text-red-400 hover:text-red-600 text-sm"><i class="fa-solid fa-trash-can"></i> 삭제</button></div><input type="text" value="${item.q}" oninput="quizData[4][${gIdx}].q = this.value; saveQuizToLocal();" class="w-full p-3 border rounded-xl font-bold text-slate-800 focus:border-amber-500 outline-none"><div class="grid grid-cols-1 md:grid-cols-2 gap-3">${item.a.map((opt, oIdx) => `<div class="flex items-center gap-2 text-slate-400"><i class="fa-regular fa-circle text-xs"></i><input type="text" value="${opt}" oninput="quizData[4][${gIdx}].a[${oIdx}] = this.value; saveQuizToLocal();" class="flex-1 p-2 border rounded-lg text-sm outline-none text-slate-700"></div>`).join('')}</div>`;
                listContainer.appendChild(card);
            });
            renderPagination('survey-pagination', survey.length, currentSurveyPage, (p) => { currentSurveyPage = p; loadSurveyEdit(); });
        }

        function removeQuestion(u, idx) {
            if(quizData[u].length <= 1) return showAlert("최소 한 개는 있어야 합니다.");
            customConfirm("삭제하시겠습니까?", () => { 
                quizData[u].splice(idx, 1); saveQuizToLocal();
                if(u === 4) loadSurveyEdit(); else loadQuizEdit(u);
                showAlert("삭제되었습니다."); 
            });
        }

        function addNewQuestionToUnit() { quizData[editingUnit].push({ q: "새로운 질문", a: ["보기 1", "보기 2", "보기 3", "보기 4"], correct: 0 }); saveQuizToLocal(); currentQuizPage = Math.ceil(quizData[editingUnit].length/ITEMS_PER_PAGE); loadQuizEdit(editingUnit); }
        function addNewSurveyToUnit() { quizData[4].push({ q: "새로운 설문 문항", a: ["매우 그렇다", "그렇다", "보통이다", "그렇지 않다"], correct: -1 }); saveQuizToLocal(); currentSurveyPage = Math.ceil(quizData[4].length/ITEMS_PER_PAGE); loadSurveyEdit(); }

        function toggleStartButton() { const name = document.getElementById('student-name').value.trim(); const btn = document.getElementById('start-btn'); btn.disabled = name.length === 0; btn.className = btn.disabled ? "w-full bg-slate-200 text-slate-400 font-bold py-4 rounded-xl shadow-lg cursor-not-allowed" : "w-full bg-blue-600 text-white font-bold py-4 rounded-xl shadow-lg hover:bg-blue-700"; }
        function toggleTeacherLoginButton() { const pw = document.getElementById('teacher-pw').value.trim(); const btn = document.getElementById('teacher-login-btn'); btn.disabled = pw.length === 0; btn.className = btn.disabled ? "flex-1 py-3 bg-slate-200 text-slate-400 font-bold rounded-xl" : "flex-1 py-3 bg-blue-600 text-white font-bold rounded-xl hover:bg-blue-700 shadow-md"; }
        function openTeacherAuth() { document.getElementById('teacher-login-modal').classList.add('active'); document.getElementById('teacher-pw').focus(); }
        function closeTeacherAuth() { document.getElementById('teacher-login-modal').classList.remove('active'); document.getElementById('teacher-pw').value = ""; }
        function processLogin() { if (document.getElementById('teacher-pw').value === MASTER_PW) { closeTeacherAuth(); showPage('teacher-dashboard-page'); switchTeacherTab('results'); } else { document.getElementById('pw-error-msg').classList.remove('hidden'); } }

        function startAssessment() { currentStudent = document.getElementById('student-name').value.trim(); currentUnit = 1; scores = {1:0, 2:0, 3:0, 4:0}; quizAnswers = {1:[], 2:[], 3:[]}; surveyAnswers = {4: []}; showUnitIntro(); }

        function showUnitIntro() {
            const info = unitInfo[currentUnit];
            document.getElementById('unit-number-label').innerText = `UNIT 0${currentUnit}`;
            document.getElementById('unit-intro-title').innerText = info.title;
            document.getElementById('unit-intro-desc').innerText = info.desc;
            document.getElementById('unit-icon-box').innerHTML = `<i class="fa-solid ${info.icon}"></i>`;
            document.getElementById('unit-action-btn-text').innerText = currentUnit === 4 ? "점검 시작하기" : "문제 풀기 시작";
            showPage('unit-intro-page');
        }

        function goToQuiz() { currentQuestionIdx = 0; showPage('quiz-page'); renderQuestion(); }

        let tempSelectedIdx = -1;
        function renderQuestion() {
            const questions = quizData[currentUnit];
            const q = questions[currentQuestionIdx];
            document.getElementById('unit-tag').innerText = `${currentUnit}단원: ${unitInfo[currentUnit].title}`;
            document.getElementById('quiz-progress').innerText = `문항 ${currentQuestionIdx + 1} / ${questions.length}`;
            document.getElementById('progress-bar-fill').style.width = `${((currentQuestionIdx + 1) / questions.length) * 100}%`;
            document.getElementById('question-text').innerText = q.q;
            const container = document.getElementById('options-container');
            container.innerHTML = '';
            tempSelectedIdx = -1;
            q.a.forEach((opt, idx) => {
                const btn = document.createElement('div');
                btn.className = "p-5 border-2 border-slate-100 rounded-2xl cursor-pointer hover:bg-blue-50 flex items-center gap-4 group";
                btn.innerHTML = `<div class="w-6 h-6 rounded-full border-2 border-slate-200 flex items-center justify-center group-hover:border-blue-500"><div class="dot w-3 h-3 rounded-full bg-blue-600 hidden"></div></div><span class="text-slate-700 font-medium">${opt}</span>`;
                btn.onclick = () => {
                    document.querySelectorAll('#options-container .dot').forEach(d => d.classList.add('hidden'));
                    btn.querySelector('.dot').classList.remove('hidden');
                    tempSelectedIdx = idx;
                    document.getElementById('next-btn').disabled = false;
                    document.getElementById('next-btn').className = "w-full bg-blue-600 text-white font-bold py-4 rounded-xl shadow-lg";
                };
                container.appendChild(btn);
            });
            document.getElementById('next-btn').disabled = true;
            document.getElementById('next-btn').className = "w-full bg-slate-100 text-slate-300 font-bold py-4 rounded-xl cursor-not-allowed";
        }

        function handleNextQuestion() {
            if (currentUnit === 4) {
                surveyAnswers[4][currentQuestionIdx] = tempSelectedIdx;
            } else {
                quizAnswers[currentUnit][currentQuestionIdx] = tempSelectedIdx;
                if (tempSelectedIdx === quizData[currentUnit][currentQuestionIdx].correct) scores[currentUnit]++;
            }
            currentQuestionIdx++;
            if (currentQuestionIdx >= quizData[currentUnit].length) {
                if (currentUnit < 4) { currentUnit++; showUnitIntro(); } 
                else { finalizeAssessment(); }
            } else { renderQuestion(); }
        }

        function finalizeAssessment() {
            const record = { 
                id: Date.now(), name: currentStudent, date: new Date().toLocaleDateString(), 
                scores: { ...scores }, quizAnswers: JSON.parse(JSON.stringify(quizAnswers)), surveyAnswers: JSON.parse(JSON.stringify(surveyAnswers)),
                autoFeedback: "평가가 완료되었습니다.", teacherComment: "" 
            };
            assessmentRecords.push(record);
            document.getElementById('result-name').innerText = currentStudent;
            renderResultSummary();
            showPage('result-page');
        }

        function renderResultSummary() {
            const summary = document.getElementById('result-summary');
            summary.innerHTML = '';
            for(let i=1; i<=4; i++) {
                const max = quizData[i].length;
                let contentHTML = '';
                if(i === 4) {
                    contentHTML = `<span class="bg-green-100 text-green-700 px-3 py-1 rounded-lg text-xs font-bold">참여 완료</span>`;
                } else {
                    contentHTML = `<div class="flex flex-col items-end">${getStarHTML(scores[i], max)}<span class="text-xs text-slate-400 mt-1 font-medium">${scores[i]} / ${max}</span></div>`;
                }
                summary.innerHTML += `<div class="p-6 bg-slate-50 border border-slate-100 rounded-2xl flex justify-between items-center"><div><p class="text-xs font-bold text-slate-400 mb-1">UNIT 0${i}</p><h4 class="font-bold text-slate-700">${unitInfo[i].title}</h4></div>${contentHTML}</div>`;
            }
        }

        function showTeacherDashboard() {
            const body = document.getElementById('student-list-body');
            body.innerHTML = '';
            const reversed = [...assessmentRecords].reverse();
            const start = (currentResultsPage - 1) * ITEMS_PER_PAGE;
            const paged = reversed.slice(start, start + ITEMS_PER_PAGE);
            paged.forEach(rec => {
                let totalScore = 0; let totalMax = 0;
                for(let k=1; k<=3; k++) { totalScore += rec.scores[k]; totalMax += quizData[k].length; }
                const avg = totalMax > 0 ? (totalScore / totalMax) * 5 : 0;
                const tr = document.createElement('tr');
                tr.className = "border-b hover:bg-slate-50";
                tr.innerHTML = `<td class="p-4 text-slate-500 text-sm">${rec.date}</td><td class="p-4 font-bold text-slate-800">${rec.name}</td><td class="p-4">${getStarHTML(avg)}</td><td class="p-4"><button onclick="loadDetail(${rec.id})" class="text-blue-600 font-bold text-xs bg-blue-50 px-3 py-1.5 rounded-lg">상세보기</button></td>`;
                body.appendChild(tr);
            });
            renderPagination('results-pagination', assessmentRecords.length, currentResultsPage, (p) => { currentResultsPage = p; showTeacherDashboard(); });
        }

        function getStarHTML(score, max = 5) {
            const p = (score / max) * 100;
            return `<div class="star-rating"><div class="stars text-slate-200"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div><div class="filled" style="width: ${p}%"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div></div>`;
        }

        function loadDetail(id) {
            const rec = assessmentRecords.find(r => r.id === id);
            viewingId = id;
            document.getElementById('detail-student-name').innerText = rec.name;
            document.getElementById('auto-feedback').value = rec.autoFeedback;
            document.getElementById('teacher-comment').value = rec.teacherComment;
            
            // 데이터 미리 준비
            renderDetailReport(rec);
            renderDetailAnalysis(rec);
            
            showPage('teacher-detail-page');
        }

        function renderDetailReport(rec) {
            const container = document.getElementById('detail-stats-container');
            container.innerHTML = `<h3 class="text-2xl font-black mb-8 text-slate-800">${rec.name} 성취도 리포트</h3>`;
            for(let i=1; i<=3; i++) {
                const max = quizData[i].length;
                const perc = (rec.scores[i]/max)*100;
                container.innerHTML += `<div class="p-6 bg-slate-50 rounded-2xl border border-slate-100"><div class="flex justify-between items-center mb-3"><span class="font-bold text-slate-700">${unitInfo[i].title}</span><span class="text-blue-600 font-bold">${rec.scores[i]} / ${max}</span></div><div class="w-full bg-slate-200 h-3 rounded-full overflow-hidden"><div class="bg-blue-600 h-full transition-all duration-700" style="width:${perc}%"></div></div></div>`;
            }
        }

        function renderDetailAnalysis(rec) {
            const analysisBody = document.getElementById('question-analysis-body');
            analysisBody.innerHTML = '';
            for(let u=1; u<=3; u++) {
                const questions = quizData[u];
                const answers = rec.quizAnswers[u] || [];
                questions.forEach((q, qIdx) => {
                    const studentChoice = answers[qIdx];
                    const correctChoice = q.correct;
                    const isCorrect = studentChoice === correctChoice;
                    
                    const tr = document.createElement('tr');
                    tr.className = "border-b hover:bg-slate-50";
                    tr.innerHTML = `
                        <td class="p-4">
                            <p class="text-xs text-blue-600 font-bold mb-1">${u}단원</p>
                            <p class="text-sm font-bold text-slate-800">${qIdx + 1}. ${q.q}</p>
                        </td>
                        <td class="p-4 text-sm ${isCorrect ? 'text-slate-600' : 'text-red-500 font-bold'}">
                            ${studentChoice !== undefined ? (studentChoice + 1) + '. ' + q.a[studentChoice] : '-'}
                        </td>
                        <td class="p-4 text-sm text-blue-600 font-bold">
                            ${correctChoice + 1}. ${q.a[correctChoice]}
                        </td>
                        <td class="p-4 text-center">
                            ${isCorrect ? '<i class="fa-solid fa-circle-check text-green-500 text-xl"></i>' : '<i class="fa-solid fa-circle-xmark text-red-500 text-xl"></i>'}
                        </td>
                    `;
                    analysisBody.appendChild(tr);
                });
            }
        }

        function openDetailModal(type) {
            const modal = document.getElementById('detail-modal');
            const title = document.getElementById('modal-title');
            const report = document.getElementById('modal-report-content');
            const analysis = document.getElementById('modal-analysis-content');
            
            report.classList.add('hidden');
            analysis.classList.add('hidden');
            
            if(type === 'report') {
                title.innerText = "성취도 리포트";
                report.classList.remove('hidden');
            } else {
                title.innerText = "문항별 정오답 분석";
                analysis.classList.remove('hidden');
            }
            modal.classList.add('active');
        }

        function closeDetailModal() {
            document.getElementById('detail-modal').classList.remove('active');
        }

        function showSurveyResultPage() {
            const rec = assessmentRecords.find(r => r.id === viewingId);
            document.getElementById('survey-result-name').innerText = rec.name;
            const list = document.getElementById('survey-result-list');
            list.innerHTML = '';
            const surveyQuestions = quizData[4];
            const studentAnswers = rec.surveyAnswers[4] || [];
            surveyQuestions.forEach((q, idx) => {
                const div = document.createElement('div');
                div.className = "p-6 bg-slate-50 rounded-2xl border border-slate-200";
                const selectedIdx = studentAnswers[idx];
                div.innerHTML = `<p class="text-sm text-slate-400 font-bold mb-2">Q${idx+1}</p><h4 class="text-lg font-bold text-slate-800 mb-4">${q.q}</h4><div class="space-y-2">${q.a.map((opt, oIdx) => `<div class="p-3 rounded-lg border ${oIdx === selectedIdx ? 'bg-blue-600 text-white border-blue-600 font-bold' : 'bg-white text-slate-500 border-slate-100'}">${opt}</div>`).join('')}</div>`;
                list.appendChild(div);
            });
            showPage('survey-result-page');
        }

        function saveFeedbackChanges() {
            const rec = assessmentRecords.find(r => r.id === viewingId);
            if(rec) {
                rec.autoFeedback = document.getElementById('auto-feedback').value;
                rec.teacherComment = document.getElementById('teacher-comment').value;
                showAlert("피드백이 성공적으로 저장되었습니다.");
            }
        }

        function resetToHome() { document.getElementById('student-name').value = ""; toggleStartButton(); showPage('main-page'); }
    </script>
</body>
</html>
